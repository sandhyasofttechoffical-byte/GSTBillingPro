<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F8FAFC">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header_gradient"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="Sold Products"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?android:attr/homeAsUpIndicator" />

    <!-- Header card: tabs + search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="3dp">

        <!-- Date Filter Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabDateFilter"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/white"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextColor="#5B7088"
            app:tabSelectedTextColor="#4A6FA5"
            app:tabIndicatorColor="#4A6FA5"
            app:tabIndicatorHeight="3dp"
            app:tabTextAppearance="@android:style/TextAppearance.Widget.TabWidget" />

        <!-- Search -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchSoldProducts"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/search_view_background"
            android:iconifiedByDefault="false"
            android:queryHint="Search by product, customer, date"
            app:iconTint="#4A6FA5"
            app:searchIcon="@drawable/ic_search"
            app:closeIcon="@drawable/ic_close"
            app:searchHintIcon="@drawable/ic_search"
            app:queryBackground="@android:color/transparent" />

    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSoldProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:scrollbars="vertical" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No sold products found."
        android:textAlignment="center"
        android:textColor="#5B7088"
        android:textSize="15sp"
        android:padding="32dp"
        android:visibility="gone"
        android:gravity="center" />

</LinearLayout>