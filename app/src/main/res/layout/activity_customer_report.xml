<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/imgBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Customer Reports"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Date Filter Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DATE FILTER"
                android:textColor="#5B7088"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <!-- Date Range Display -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Date Range Label with Icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="#4A6FA5"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/tvDateRange"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="All dates"
                            android:textColor="#0D2137"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearFilter"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Clear"
                            android:textSize="12sp"
                            android:textColor="#5B7088"
                            app:strokeColor="#D0D8E0"
                            app:strokeWidth="1dp"
                            app:cornerRadius="18dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <!-- Date Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFromDate"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="📅  From"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            app:icon="@drawable/ic_calendar"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:cornerRadius="10dp"
                            app:backgroundTint="#1B5EAB"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="6dp"
                            app:elevation="2dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnToDate"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="📅  To"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            app:icon="@drawable/ic_calendar"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:cornerRadius="10dp"
                            app:backgroundTint="#1B5EAB"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="6dp"
                            app:elevation="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Section: All Reports -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ALL DATA REPORTS"
                android:textColor="#5B7088"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <!-- 1. All Invoices -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#EEF1F5"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:id="@+id/cardAllInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_file_pdf"
                        app:tint="#4A6FA5" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All Invoices Report"
                            android:textColor="#0D2137"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Invoice No, Customer, Date, Total"
                            android:textColor="#5B7088"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#5B7088" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Pending Payments -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#FFDDD0"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#FFF8F5">

                <LinearLayout
                    android:id="@+id/cardPendingReport"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_file_pdf"
                        app:tint="#E05C00" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending Payments Report"
                            android:textColor="#0D2137"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Customer, Invoice, Total, Paid, Due"
                            android:textColor="#5B7088"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#5B7088" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Completed Payments -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#C8F0D8"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#F5FFF8">

                <LinearLayout
                    android:id="@+id/cardCompletedReport"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_file_pdf"
                        app:tint="#1B7832" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completed Payments Report"
                            android:textColor="#0D2137"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Customer, Invoice, Amount, Date"
                            android:textColor="#5B7088"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#5B7088" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0.8dp"
                    android:layout_weight="1"
                    android:background="#EEF1F5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  CUSTOMER SPECIFIC  "
                    android:textColor="#5B7088"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.08" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0.8dp"
                    android:layout_weight="1"
                    android:background="#EEF1F5" />

            </LinearLayout>

            <!-- 4. Customer Statement -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#C8D8F5"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#F0F5FF">

                <LinearLayout
                    android:id="@+id/cardCustomerStatement"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_customer"
                        app:tint="#4A6FA5" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Customer Invoice Statement"
                            android:textColor="#0D2137"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select customer → full history PDF"
                            android:textColor="#5B7088"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#5B7088" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Customer Pending Only -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="#FFDDD0"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#FFF8F5">

                <LinearLayout
                    android:id="@+id/cardCustomerPending"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_customer"
                        app:tint="#E05C00" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Customer Pending Report"
                            android:textColor="#0D2137"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select customer → pending dues only"
                            android:textColor="#5B7088"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#5B7088" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Status -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EEF4FF">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#4A6FA5"
                    android:textSize="12.5sp"
                    android:textAlignment="center"
                    android:fontFamily="sans-serif"
                    android:padding="12dp"
                    android:text="Select a report to generate PDF" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>