<?xml version="1.0" encoding="utf-8"?>
<!-- Professional & Responsive Add Product Layout (English Only) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/off_white">

    <!-- Modern Toolbar with Gradient Background and Elevation -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_header_gradient"
        android:elevation="4dp"
        app:title="Add Product"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="Back"
        app:titleTextColor="@android:color/white"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Widget.ActionBar.Title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/off_white"
        android:padding="16dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Intro text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Product"
                android:textColor="@color/text_dark"
                android:textSize="19sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fill in the product details to add it to your inventory"
                android:textColor="@color/text_grey"
                android:textSize="13sp"
                android:layout_marginBottom="18dp" />

            <!-- ===================== CARD 1: Product Information ===================== -->
            <LinearLayout
                android:id="@+id/cardProductInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:elevation="3dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_badge">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_product"
                            app:tint="@color/blue_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Product Information"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Product Name Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilProductName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/blue_primary"
                    app:errorEnabled="true"
                    app:placeholderText="e.g., Laptop"
                    app:placeholderTextColor="@color/text_grey"
                    app:startIconDrawable="@drawable/ic_product"
                    app:startIconTint="@color/text_grey"
                    app:hintTextColor="@color/blue_primary"
                    app:errorTextColor="@color/error_red">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Product Name *"
                        android:inputType="textCapWords|textAutoCorrect"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_grey"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Unit Field with Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUnit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/blue_primary"
                    app:endIconMode="dropdown_menu"
                    app:endIconTint="@color/text_grey"
                    app:startIconDrawable="@drawable/ic_unit"
                    app:startIconTint="@color/text_grey"
                    app:hintTextColor="@color/blue_primary">

                    <AutoCompleteTextView
                        android:id="@+id/etUnit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Unit *"
                        android:inputType="none"
                        android:maxLines="1"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_grey"
                        android:popupBackground="@android:color/white"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- HSN Code Field (Initially Hidden) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHSNCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/blue_primary"
                    app:errorEnabled="true"
                    app:startIconDrawable="@drawable/ic_hash"
                    app:startIconTint="@color/text_grey"
                    app:hintTextColor="@color/blue_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHSNCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="HSN Code"
                        android:inputType="text"
                        android:maxLength="8"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_grey" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- ===================== CARD 2: Pricing & Tax ===================== -->
            <LinearLayout
                android:id="@+id/cardPricingTax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:elevation="3dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_badge">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_currency"
                            app:tint="@color/blue_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Pricing &amp; Tax"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Price Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/blue_primary"
                    app:errorEnabled="true"
                    app:startIconDrawable="@drawable/ic_currency"
                    app:startIconTint="@color/text_grey"
                    app:hintTextColor="@color/blue_primary"
                    app:prefixText="₹"
                    app:prefixTextColor="@color/blue_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Price *"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_grey"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GST Rate Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGSTRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/blue_primary"
                    app:errorEnabled="true"
                    app:startIconDrawable="@drawable/ic_percent"
                    app:startIconTint="@color/text_grey"
                    app:hintTextColor="@color/blue_primary"
                    app:suffixText="%"
                    app:suffixTextColor="@color/blue_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etGSTRate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="GST Rate"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_grey"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- ===================== CARD 3: Stock ===================== -->
            <LinearLayout
                android:id="@+id/cardStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:elevation="3dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_badge">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_stock"
                            app:tint="@color/blue_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Stock"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Stock Quantity Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilStockQuantity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxStrokeColor="@color/blue_primary"
                    app:errorEnabled="true"
                    app:startIconDrawable="@drawable/ic_stock"
                    app:startIconTint="@color/text_grey"
                    app:hintTextColor="@color/blue_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStockQuantity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Stock Quantity *"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_grey"
                        android:importantForAutofill="no" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- ===================== Custom Fields (dynamic, hidden until populated) ===================== -->
            <LinearLayout
                android:id="@+id/cardCustomFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:elevation="3dp"
                android:padding="18dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_icon_badge">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/blue_primary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Additional Details"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Dynamic Custom Fields Container -->
                <LinearLayout
                    android:id="@+id/llCustomFieldsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:animateLayoutChanges="true" />

            </LinearLayout>

            <!-- ===================== Buttons Section ===================== -->
            <LinearLayout
                android:id="@+id/buttonGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp">

                <!-- Save Product Button (Primary) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveProduct"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_button_selector"
                    app:cornerRadius="28dp"
                    app:rippleColor="@color/blue_soft"
                    app:elevation="4dp"
                    android:stateListAnimator="@null"
                    android:text="Save Product"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:icon="@drawable/ic_save"
                    app:iconGravity="textStart"
                    app:iconTint="@android:color/white"
                    app:iconPadding="8dp" />

                <!-- Manage Custom Fields Button (Outlined) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/customfields"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Manage Custom Fields"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:visibility="gone"
                    android:textStyle="normal"
                    app:cornerRadius="25dp"
                    app:strokeColor="@color/blue_primary"
                    app:strokeWidth="1.5dp"
                    android:textColor="@color/blue_primary"
                    app:icon="@drawable/ic_settings"
                    app:iconGravity="textStart"
                    app:iconTint="@color/blue_primary"
                    app:iconPadding="8dp"
                    app:rippleColor="@color/blue_soft" />
            </LinearLayout>

            <!-- Additional bottom padding for better scrolling -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>