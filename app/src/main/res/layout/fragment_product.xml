<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true"
    tools:context=".Fragment.ProductFragment">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/header_shadow"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/search_view_background"
            android:elevation="2dp"
            android:iconifiedByDefault="false"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:queryHint="@string/hint_search_products"
            android:textColor="#1E293B"
            app:closeIcon="@drawable/ic_close"
            app:iconTint="#4A6FA5"
            app:queryBackground="@android:color/transparent"
            app:searchHintIcon="@drawable/ic_search"
            app:searchIcon="@drawable/ic_search" />

        <TextView
            android:id="@+id/tvTotalProducts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:background="@drawable/counter_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="3dp"
            android:textColor="#4A6FA5"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="Total Products: 24" />

    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:clipToPadding="false"
        android:fadeScrollbars="true"
        android:overScrollMode="ifContentScrolls"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="90dp"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        android:scrollbarTrackVertical="@drawable/scrollbar_track"
        android:scrollbars="vertical"
        tools:listitem="@layout/item_product" />

    <!-- Hidden import button — kept in tree so Java finds it, but invisible -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnImportProducts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- FAB floating over RecyclerView, pinned bottom-end -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddProduct"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/blue"
        android:clickable="true"
        android:contentDescription="@string/desc_add_product"
        android:elevation="8dp"
        android:focusable="true"
        android:src="@drawable/ic_add"
        app:borderWidth="0dp"
        app:fabSize="normal"
        app:rippleColor="#33FFFFFF"
        app:tint="@android:color/white" />

</RelativeLayout>