<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient"
    android:fitsSystemWindows="true">

    <!-- Outer glow ring behind the logo card -->
    <FrameLayout
        android:id="@+id/logoGlow"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_logo_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/appName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="160dp"
        android:layout_marginBottom="20dp">

        <!-- White circular card holding the logo -->
        <FrameLayout
            android:id="@+id/logoCard"
            android:layout_width="156dp"
            android:layout_height="156dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_logo_card"
            android:elevation="8dp">

            <!-- Company Logo Image -->
            <ImageView
                android:id="@+id/companyLogo"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:layout_gravity="center"
                android:src="@drawable/fixlogo"
                android:contentDescription="Company Logo"
                android:scaleType="centerInside" />
        </FrameLayout>
    </FrameLayout>

    <!-- App Name -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GST BILLING"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:letterSpacing="0.04"
        android:fontFamily="sans-serif-medium"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/logoGlow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Simplify your GST billing"
        android:textColor="#CFE3FA"
        android:textSize="15sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.02"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/appName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Loading dots indicator -->
    <LinearLayout
        android:id="@+id/loadingDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0"
        app:layout_constraintBottom_toTopOf="@id/footerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot" />
    </LinearLayout>

    <!-- Footer with Company and Made in India -->
    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="28dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <ImageView
                android:id="@+id/indiaFlag"
                android:layout_width="22dp"
                android:layout_height="15dp"
                android:src="@drawable/flag"
                android:contentDescription="Made in India" />

            <TextView
                android:id="@+id/madeInIndiaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Made in India"
                android:textColor="#E8F1FC"
                android:textSize="14sp"
                android:textStyle="normal"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/companyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SANDHYA SOFTTECH PVT LTD"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:alpha="0.85"
            android:gravity="center" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>