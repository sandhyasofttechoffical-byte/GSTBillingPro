<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/off_white"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ============ CURVED BLUE HEADER PANEL ============ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="260dp">

            <com.sandhyasofttech.gstbillingpro.Registration.CurvedHeaderView
                android:id="@+id/curvedHeader"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Logo + brand text sit on the curve -->
            <LinearLayout
                android:id="@+id/brandBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="46dp"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:background="@drawable/bg_logo_ring"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:id="@+id/app_logo"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_gravity="center"
                        android:src="@drawable/fixlogo"
                        android:contentDescription="GST Bill Pro Logo" />
                </FrameLayout>

                <TextView
                    android:id="@+id/loginTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GST Bill Pro"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/subTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in to manage billing"
                    android:textSize="13sp"
                    android:textColor="#D6E6FA" />

            </LinearLayout>
        </FrameLayout>

        <!-- ============ FLOATING FORM CARD (overlaps the curve) ============ -->
        <LinearLayout
            android:id="@+id/loginFormCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="-56dp"
            android:orientation="vertical"
            android:background="@drawable/bg_login_card"
            android:elevation="10dp"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome back"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your mobile number and PIN to continue"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:layout_marginBottom="20dp" />

            <!-- Mobile Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/phoneInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxStrokeColor="@color/blue_primary"
                app:hintTextColor="@color/blue_primary"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/text_grey"
                app:counterEnabled="true"
                app:counterMaxLength="10">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mobile Number"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:inputType="phone"
                    android:maxLength="10" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- PIN Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/pinInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxStrokeColor="@color/blue_primary"
                app:hintTextColor="@color/blue_primary"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/text_grey"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_grey"
                app:counterEnabled="true"
                app:counterMaxLength="4">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/pinInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="4-digit PIN"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:inputType="numberPassword"
                    android:maxLength="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Login Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@null"
                android:background="@drawable/bg_button_selector"
                app:cornerRadius="28dp"
                app:rippleColor="@color/blue_soft"
                app:elevation="2dp"
                android:stateListAnimator="@null"
                android:text="Login"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Registration link -->
        <TextView
            android:id="@+id/registrationLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="28dp"
            android:text="Don't have an account? Register Now"
            android:textColor="@color/blue_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="6dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>